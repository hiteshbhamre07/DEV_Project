# ─── Application ──────────────────────────────────────────────────────────────
# REQUIRED: Set a strong random secret for JWT signing (e.g. openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-me

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+psycopg2://<user>:<password>@<host>/<dbname>
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost/rp_crm_db
